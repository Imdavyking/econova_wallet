# ─────────────────────────────────────────────────────────────────────────────
# Econova Wallet — Environment Variables
# Copy this file to .env and fill in your own keys.
# All services below offer free tier accounts.
# ─────────────────────────────────────────────────────────────────────────────

# Covalent — https://www.covalenthq.com
COVAL_API_KEY=

# Alchemy — https://dashboard.alchemy.com
ALCHEMY_ETH_MAINNET=
ALCHEMY_ETH_GOERLI=
ALCHEMY_ARBITRUM=
ALCHEMY_MUMBAI=
ALCHEMY_POLYGON=

# Ramp — https://ramp.network/configuration
RAMP_API_KEY=

# BSCScan — https://bscscan.com/apis
BSC_API_KEY=

# TronGrid — https://www.trongrid.io
TRON_GRID_API_KEY=

# Infura — https://infura.io
INFURA_API_KEY=

# WalletConnect — https://cloud.walletconnect.com
WALLET_CONNECT_KEY=

# CoinMarketCap — https://coinmarketcap.com/api
COIN_MARKET_CAP_KEY=

# BlastAPI — https://blastapi.io
BLAST_API_PROJECT_ID=

# Tatum (UTXO) — https://tatum.io
UTXO_API_KEY=

# PureStake (Algorand) — https://developer.purestake.io
PURE_STAKE_API_KEY=

# Nano — https://rpc.nano.to
NANO_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
